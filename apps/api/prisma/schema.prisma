// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  username             String?    @unique
  passwordHash         String
  role                 String     @default("user") // admin, staff, user
  isVerified           Boolean    @default(false)
  isBanned             Boolean    @default(false)
  lastIp               String?
  lastOs               String?
  lastDevice           String?
  allowedTabs          String?    // Comma-separated or JSON list of allowed tabs

  otpCode              String?
  otpExpiresAt         DateTime?

  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  proxies        Proxy[]
  accounts       TikTokAccount[]
  feedbacks      Feedback[]
  tabPermissions TabPermission[]
}

model Proxy {
  id        String   @id @default(uuid())
  ip        String
  port      Int
  username  String?
  password  String?
  country   String
  status    String   @default("active") // active, dead, flagged
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  accounts  TikTokAccount[]
}

model TikTokAccount {
  id           String   @id @default(uuid())
  username     String   @unique
  cookies      String?  // JSON string
  status       String   @default("active") // active, shadowbanned, banned
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  proxyId      String?
  proxy        Proxy?   @relation(fields: [proxyId], references: [id])
  
  tasks        VideoTask[]
}

model VideoTask {
  id             String   @id @default(uuid())
  sourceVideoUrl String
  status         String   @default("pending") // pending, processing, uploaded, failed
  
  accountId      String
  account        TikTokAccount @relation(fields: [accountId], references: [id])
  
  createdAt      DateTime @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  content   String
  target    String   @default("all") // all, user, staff
  isRead    Boolean  @default(false)
  expiresAt DateTime? // 1h, 12h, 24h, 7d, 30d
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid())
  sender    String   // user, ai, staff
  message   String
  userId    String?
  createdAt DateTime @default(now())
}

model TabPermission {
  id        String   @id @default(uuid())
  userId    String
  tabKey    String   // "ho-so", "cong-cu", "settings", "feedback", etc.
  visible   Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tabKey])
}
