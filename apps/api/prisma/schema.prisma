// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  username             String?    @unique
  passwordHash         String
  role                 String     @default("user") // admin, user
  isVerified           Boolean    @default(false)

  otpCode              String?
  otpExpiresAt         DateTime?

  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  proxies   Proxy[]
  accounts  TikTokAccount[]
  feedbacks Feedback[]
}

model Proxy {
  id        String   @id @default(uuid())
  ip        String
  port      Int
  username  String?
  password  String?
  country   String
  status    String   @default("active") // active, dead, flagged
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  accounts  TikTokAccount[]
}

model TikTokAccount {
  id           String   @id @default(uuid())
  username     String   @unique
  cookies      String?  // JSON string
  status       String   @default("active") // active, shadowbanned, banned
  
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  proxyId      String?
  proxy        Proxy?   @relation(fields: [proxyId], references: [id])
  
  tasks        VideoTask[]
}

model VideoTask {
  id             String   @id @default(uuid())
  sourceVideoUrl String
  status         String   @default("pending") // pending, processing, uploaded, failed
  
  accountId      String
  account        TikTokAccount @relation(fields: [accountId], references: [id])
  
  createdAt      DateTime @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
}
